---
import { Plus } from "@lucide/astro";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  title: string;
  photo?: ImageMetadata | string;
  Content: any;
  link?: string;
}

const { title, photo, Content, link } = Astro.props;
---

<section id="about" class="py-16 px-4 fade-up">
  <div class="max-w-5xl mx-auto">
    <div class="card card-side bg-base-200 shadow-sm flex-col lg:flex-row">
      {
        photo && (
          <figure class="shrink-0 w-full lg:w-64">
            {typeof photo === "string" ? (
              <img src={photo} alt={title} class="w-full h-48 lg:h-full object-cover" />
            ) : (
              <Image src={photo} alt={title} class="w-full h-48 lg:h-full object-cover" />
            )}
          </figure>
        )
      }
      <div class="card-body">
        <h2 class="card-title text-3xl mb-4">{title}</h2>
        <article
          class="prose max-w-none prose-lg prose-a:text-primary prose-a:underline prose-a:hover:opacity-80"
        >
          <Content />
        </article>
        {
          link && (
            <div class="card-actions justify-end mt-4">
              <a href={link} target="_blank" class="btn btn-primary">
                <Plus class="size-5" />
                More about me
              </a>
            </div>
          )
        }
      </div>
    </div>
  </div>
</section>
